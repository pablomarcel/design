```python
import sympy as sp
import numpy as np
import matplotlib.pyplot as plt
from matplotlib.animation import FuncAnimation

# ------------------------------------------------
# Cam motion definition (same as mechanism example)
# ------------------------------------------------

motion = [
    ('Rise', 3, 90),
    ('Dwell', 15),
    ('Fall', 3, 90),
    ('Dwell', 15),
    ('Rise', 2, 60),
    ('Dwell', 15),
    ('Fall', 2, 60),
    ('Dwell', 15)
]

omega = np.pi
roller_radius = 1
base_radius = 4


# ------------------------------------------------
# Cycloidal motion law
# ------------------------------------------------

theta = sp.symbols('theta')
beta = sp.symbols('beta')
h = sp.symbols('h')

cycloidal_rise = h * (theta/beta - (1/(2*sp.pi))*sp.sin(2*sp.pi*theta/beta))
cycloidal_fall = h * (1 - (theta/beta - (1/(2*sp.pi))*sp.sin(2*sp.pi*theta/beta)))

rise_func = sp.lambdify((theta, beta, h), cycloidal_rise, 'numpy')
fall_func = sp.lambdify((theta, beta, h), cycloidal_fall, 'numpy')


# ------------------------------------------------
# Generate cam displacement curve
# ------------------------------------------------

angles = []
disp = []

current_angle = 0

for seg in motion:

    if seg[0] == 'Rise':
        height, deg = seg[1], seg[2]
        local = np.linspace(0, deg, 50)
        s = rise_func(local, deg, height)

    elif seg[0] == 'Fall':
        height, deg = seg[1], seg[2]
        local = np.linspace(0, deg, 50)
        s = fall_func(local, deg, height)

    elif seg[0] == 'Dwell':
        deg = seg[1]
        local = np.linspace(0, deg, 30)
        s = np.ones_like(local) * disp[-1] if disp else np.zeros_like(local)

    global_theta = current_angle + local

    angles.extend(global_theta)
    disp.extend(s)

    current_angle += local[-1]

angles = np.radians(np.array(angles))
disp = np.array(disp)


# ------------------------------------------------
# Cam profile coordinates
# ------------------------------------------------

pitch_radius = base_radius + disp

x = pitch_radius * np.cos(angles)
y = pitch_radius * np.sin(angles)

cam_x = x - roller_radius*np.cos(angles)
cam_y = y - roller_radius*np.sin(angles)


# ------------------------------------------------
# Plot cam profile
# ------------------------------------------------

plt.figure()
plt.plot(cam_x, cam_y, label="Cam profile")
plt.plot(x, y, '--', label="Pitch curve")
circle = plt.Circle((0,0), base_radius, fill=False)
plt.gca().add_patch(circle)

plt.axis('equal')
plt.legend()
plt.title("Cam profile")
plt.show()


# ------------------------------------------------
# Animation
# ------------------------------------------------

fig, ax = plt.subplots()

ax.set_aspect('equal')
ax.set_xlim(-10,10)
ax.set_ylim(-10,10)

cam_line, = ax.plot([], [], lw=2)
follower_line, = ax.plot([], [], lw=4)

cam_outline = np.vstack((cam_x, cam_y))


def update(frame):

    rot = angles[frame]

    R = np.array([
        [np.cos(rot), -np.sin(rot)],
        [np.sin(rot),  np.cos(rot)]
    ])

    rotated = R @ cam_outline

    cam_line.set_data(rotated[0], rotated[1])

    follower_height = base_radius + disp[frame]

    follower_line.set_data([0,0],[0,follower_height])

    return cam_line, follower_line


ani = FuncAnimation(fig, update, frames=len(angles), interval=40)

plt.show()
```

